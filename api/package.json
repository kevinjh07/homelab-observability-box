{
  "name": "homelab-api",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc",
    "start": "node -r ./dist/tracing.js dist/index.js",
    "dev": "ts-node -r ./src/tracing.ts src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "0.57.1",
    "@opentelemetry/exporter-trace-otlp-http": "0.57.2",
    "@opentelemetry/sdk-node": "0.57.2",
    "express": "4.22.2",
    "prom-client": "15.1.3"
  },
  "devDependencies": {
    "@types/express": "4.17.25",
    "@types/node": "24.12.4",
    "@types/supertest": "6.0.3",
    "@vitest/coverage-v8": "3.2.6",
    "supertest": "7.2.2",
    "typescript": "5.9.3",
    "vitest": "3.2.6"
  }
}
